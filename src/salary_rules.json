{
  "rules": [
    {
      "id": "e62fa684-715b-4db0-b455-9741497f2cdc",
      "code": "BASIC",
      "name": "Basic Salary",
      "sequence": 1,
      "category": "earning",
      "condition": "",
      "formula": "base_salary"
    },
    {
      "id": "95200e8a-612b-4a8d-8fd4-7b338c4cfe06",
      "code": "LUNCH",
      "name": "Lunch Allowance",
      "sequence": 2,
      "category": "earning",
      "condition": "",
      "formula": "0"
    },
    {
      "id": "f5ddc908-8419-4ccf-9a38-a10b3b628649",
      "code": "PHONE",
      "name": "Phone Allowance",
      "sequence": 3,
      "category": "earning",
      "condition": "",
      "formula": "0"
    },
    {
      "id": "6f1674b8-c713-4723-b5a9-45d2da0352a2",
      "code": "OVERTIME",
      "name": "Overtime Pay",
      "sequence": 4,
      "category": "earning",
      "condition": "overtime_hours > 0",
      "formula": "overtime_hours * hourly_rate * 1.5"
    },
    {
      "id": "105c3e20-a3fa-4456-9c72-6089463919da",
      "code": "BONUS",
      "name": "Bonus",
      "sequence": 5,
      "category": "earning",
      "condition": "bonus > 0",
      "formula": "bonus"
    },
    {
      "id": "441d8834-9913-4eb9-b8b2-f0ebcc5864c5",
      "code": "SALES_BONUS",
      "name": "Sales Commission (5%)",
      "sequence": 6,
      "category": "earning",
      "condition": "sales_amount > 0",
      "formula": "sales_amount * 0.05"
    },
    {
      "id": "d319a003-70a0-4f90-b585-ba987967a697",
      "code": "GROSS",
      "name": "Gross Salary (actual)",
      "sequence": 10,
      "category": "summary",
      "condition": "",
      "formula": "BASIC + LUNCH + PHONE + OVERTIME + BONUS + SALES_BONUS"
    },
    {
      "id": "6079ac6b-3751-474e-903a-aa3bda91c0a7",
      "code": "INSURANCE_BASE",
      "name": "Insurance Base (capped 36M)",
      "sequence": 20,
      "category": "insurance",
      "condition": "insurance_enabled",
      "formula": "min(max(insurance_salary, min_wage), 36000000)"
    },
    {
      "id": "8c89e689-cd11-419a-9602-09d16d701d8c",
      "code": "BHXH",
      "name": "Social Insurance (8%)",
      "sequence": 21,
      "category": "insurance",
      "condition": "insurance_enabled",
      "formula": "INSURANCE_BASE * 0.08"
    },
    {
      "id": "dce28802-181f-4668-b21c-2c314509d204",
      "code": "BHYT",
      "name": "Health Insurance (1.5%)",
      "sequence": 22,
      "category": "insurance",
      "condition": "insurance_enabled",
      "formula": "INSURANCE_BASE * 0.015"
    },
    {
      "id": "63d74cef-3fec-4afa-bc88-3583ef790724",
      "code": "BHTN",
      "name": "Unemployment Insurance (1%)",
      "sequence": 23,
      "category": "insurance",
      "condition": "insurance_enabled",
      "formula": "INSURANCE_BASE * 0.01"
    },
    {
      "id": "1c7d7a28-d01c-46ba-8a50-82b08bd06a7d",
      "code": "TOTAL_INSURANCE",
      "name": "Total Insurance (10.5%)",
      "sequence": 24,
      "category": "insurance",
      "condition": "insurance_enabled",
      "formula": "BHXH + BHYT + BHTN"
    },
    {
      "id": "079147d3-0b67-4775-930c-9fd311a1a9b5",
      "code": "PERSONAL_DEDUCTION",
      "name": "Personal Tax Deduction",
      "sequence": 30,
      "category": "tax",
      "condition": "tax_enabled",
      "formula": "11000000"
    },
    {
      "id": "4343a284-36ae-49df-b8c1-cb38c378715d",
      "code": "DEPENDENT_DEDUCTION",
      "name": "Dependent Deduction",
      "sequence": 31,
      "category": "tax",
      "condition": "tax_enabled && dependents > 0",
      "formula": "dependents * 4400000"
    },
    {
      "id": "946e6bec-e7db-44cb-beff-2f2df64795d2",
      "code": "TAXABLE_INCOME",
      "name": "Taxable Income",
      "sequence": 32,
      "category": "tax",
      "condition": "tax_enabled",
      "formula": "max(0, GROSS - TOTAL_INSURANCE - PERSONAL_DEDUCTION - DEPENDENT_DEDUCTION)"
    },
    {
      "id": "1b44b6ab-0786-4e52-b99b-cf1ac27ad736",
      "code": "PIT",
      "name": "Personal Income Tax (TNCN)",
      "sequence": 40,
      "category": "tax",
      "condition": "tax_enabled",
      "formula": "progressive_tax(TAXABLE_INCOME)"
    },
    {
      "id": "b5fe0d14-4d22-491d-9fee-8c312ab906e5",
      "code": "NET",
      "name": "Net Salary",
      "sequence": 50,
      "category": "summary",
      "condition": "",
      "formula": "GROSS - TOTAL_INSURANCE - PIT"
    }
  ],
  "context": {
    "base_salary": 10000000,
    "insurance_salary": 4500000,
    "region": "II",
    "overtime_hours": 0,
    "hourly_rate": 48000,
    "sales_amount": 0,
    "dependents": 1,
    "bonus": 0,
    "insurance_enabled": 1,
    "tax_enabled": 1,
    "working_days": 26,
    "leave_days": 0,
    "late_minutes": 0
  }
}